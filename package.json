{
  "name": "@2bad/axiom",
  "version": "1.0.3",
  "description": "",
  "keywords": [
    "oxlint",
    "oxc",
    "linter",
    "typescript"
  ],
  "homepage": "https://github.com/2BAD/axiom#readme",
  "bugs": {
    "url": "https://github.com/2BAD/axiom/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2BAD/axiom.git"
  },
  "license": "MIT",
  "author": "2BAD (https://github.com/2BAD)",
  "contributors": [
    {
      "name": "Jason Hyde",
      "email": "github@2bad.me",
      "url": "https://github.com/mrhyde"
    }
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "run-p check:**",
    "check:code": "oxlint ./source",
    "check:format": "oxfmt --check ./source",
    "fix": "run-p fix:**",
    "fix:code": "oxlint --fix ./source",
    "fix:format": "oxfmt ./source",
    "prepublishOnly": "run-s build",
    "preversion": "run-s check test build",
    "test": "vitest run",
    "test:integration": "vitest run integration --coverage",
    "test:unit": "vitest run unit --coverage"
  },
  "devDependencies": {
    "@2bad/tsconfig": "3.0.2",
    "@arethetypeswrong/cli": "0.18.2",
    "@types/node": "25.3.3",
    "@vitest/coverage-v8": "4.0.18",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "publint": "0.3.18",
    "tsdown": "0.20.3",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "oxlint": ">= 1"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24"
  },
  "volta": {
    "node": "24.14.0",
    "pnpm": "10.30.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
